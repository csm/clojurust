(ns cljrs.compiler.optimize-test
  (:require [clojure.test :refer [deftest is testing]]
            [cljrs.compiler.optimize :as opt]))

;; ── Helpers ─────────────────────────────────────────────────────────────────

(defn ir-func
  [insts terminator next-var]
  {:name "test"
   :ns "user"
   :params []
   :blocks [{:id 0 :phis [] :insts insts :terminator terminator}]
   :next-var next-var
   :next-block 1
   :subfunctions []})

(defn alloc-vec [dst elems] {:op :alloc-vector :dst dst :elems elems})
(defn call-known [dst func args] {:op :call-known :dst dst :func func :args args})
(defn ret [v] {:op :return :var v})

;; ── alloc-op-to-region-kind ────────────────────────────────────────────────

(deftest test-alloc-op-to-region-kind-mapping
  (is (= :vector (get opt/alloc-op-to-region-kind :alloc-vector)))
  (is (= :map    (get opt/alloc-op-to-region-kind :alloc-map)))
  (is (= :set    (get opt/alloc-op-to-region-kind :alloc-set)))
  (is (= :list   (get opt/alloc-op-to-region-kind :alloc-list)))
  (is (= :cons   (get opt/alloc-op-to-region-kind :alloc-cons)))
  (testing "alloc-closure is intentionally absent — closures cannot be
            region-allocated since they outlive the call frame"
    (is (nil? (get opt/alloc-op-to-region-kind :alloc-closure))))
  (testing "non-alloc ops have no mapping"
    (is (nil? (get opt/alloc-op-to-region-kind :call-known)))
    (is (nil? (get opt/alloc-op-to-region-kind :const)))))

;; ── alloc-operands ─────────────────────────────────────────────────────────

(deftest test-alloc-operands-vector-set-list
  (is (= [1 2 3] (opt/alloc-operands {:op :alloc-vector :dst 0 :elems [1 2 3]})))
  (is (= [1 2]   (opt/alloc-operands {:op :alloc-set    :dst 0 :elems [1 2]})))
  (is (= [9 8]   (opt/alloc-operands {:op :alloc-list   :dst 0 :elems [9 8]}))))

(deftest test-alloc-operands-map-flattens-pairs
  ;; Pairs like [[k1 v1] [k2 v2]] become a flat operand list [k1 v1 k2 v2].
  (is (= [1 2 3 4]
         (opt/alloc-operands {:op :alloc-map :dst 0 :pairs [[1 2] [3 4]]}))))

(deftest test-alloc-operands-cons
  (is (= [7 8] (opt/alloc-operands {:op :alloc-cons :dst 0 :head 7 :tail 8}))))

(deftest test-alloc-operands-non-alloc-returns-empty
  (is (= [] (opt/alloc-operands (call-known 0 :+ [1 2]))))
  (is (= [] (opt/alloc-operands {:op :const :dst 0 :value {}}))))

;; ── optimize: leaves IR alone when nothing is non-escaping ──────────────────

(deftest test-optimize-no-non-escaping-allocs-is-identity
  ;; The alloc is returned, so it escapes — the optimizer must leave the
  ;; function unchanged.
  (let [f (ir-func [(alloc-vec 0 [])] (ret 0) 1)
        out (opt/optimize f)]
    (is (= f out))))

(deftest test-optimize-no-allocs-is-identity
  (let [f (ir-func [] (ret 0) 1)
        out (opt/optimize f)]
    (is (= f out))))

;; ── optimize: rewrites a non-escaping alloc into a region scope ─────────────

(defn region-insts-of-block-0 [func]
  (-> func :blocks first :insts))

(deftest test-optimize-rewrites-non-escaping-alloc
  ;; var 0 is consumed only by :count (non-escaping) → it should be rewritten
  ;; into region-alloc, with region-start at the block head and region-end
  ;; at the tail.
  (let [f (ir-func [(alloc-vec 0 [])
                    (call-known 1 :count [0])]
                   (ret 1)
                   2)
        out (opt/optimize f)
        insts (region-insts-of-block-0 out)]
    (testing "shape: [region-start, region-alloc, call-known, region-end]"
      (is (= 4 (count insts)))
      (is (= :region-start (:op (nth insts 0))))
      (is (= :region-alloc (:op (nth insts 1))))
      (is (= :call-known   (:op (nth insts 2))))
      (is (= :region-end   (:op (nth insts 3)))))
    (testing "the rewritten region-alloc preserves dst, kind, and operands"
      (let [ra (nth insts 1)]
        (is (= 0 (:dst ra)))
        (is (= :vector (:kind ra)))
        (is (= [] (:operands ra)))))
    (testing "the region-start dst matches the region argument of region-end and region-alloc"
      (let [start-var (:dst (nth insts 0))
            ra-region (:region (nth insts 1))
            end-region (:region (nth insts 3))]
        (is (= start-var ra-region))
        (is (= start-var end-region))))
    (testing ":next-var is bumped past the new region var"
      (is (>= (:next-var out) 3)))))

(deftest test-optimize-leaves-escaping-allocs-alone
  ;; var 0 is non-escaping (only :count uses it); var 1 escapes (returned).
  ;; Only var 0 should be rewritten.
  (let [f (ir-func [(alloc-vec 0 [])
                    (call-known 1 :count [0])
                    (alloc-vec 2 [1])]
                   (ret 2)
                   3)
        out (opt/optimize f)
        insts (region-insts-of-block-0 out)]
    (testing "var 0 becomes region-alloc"
      (is (some (fn [i] (and (= :region-alloc (:op i)) (= 0 (:dst i))))
                insts)))
    (testing "var 2 stays as alloc-vector (it escapes)"
      (is (some (fn [i] (and (= :alloc-vector (:op i)) (= 2 (:dst i))))
                insts)))))

;; ── optimize: subfunctions ──────────────────────────────────────────────────

(deftest test-optimize-recurses-into-subfunctions
  ;; A subfunction with a non-escaping alloc should also be optimized.
  (let [sub (ir-func [(alloc-vec 0 [])
                      (call-known 1 :count [0])]
                     (ret 1)
                     2)
        outer {:name "outer" :ns "user" :params []
               :next-var 1 :next-block 1 :subfunctions [sub]
               :blocks [{:id 0 :phis [] :insts []
                         :terminator (ret 0)}]}
        out (opt/optimize outer)
        opt-sub (first (:subfunctions out))]
    (let [insts (region-insts-of-block-0 opt-sub)]
      (is (some (fn [i] (= :region-start (:op i))) insts))
      (is (some (fn [i] (= :region-alloc (:op i))) insts))
      (is (some (fn [i] (= :region-end   (:op i))) insts)))))

(deftest test-optimize-handles-missing-subfunctions-key
  ;; The optimizer's `(or (:subfunctions optimized) [])` guard means an IR
  ;; without a :subfunctions key (legacy/data-from-elsewhere) must not crash.
  (let [f {:name "x" :ns "user" :params []
           :blocks [{:id 0 :phis [] :insts [] :terminator (ret 0)}]
           :next-var 1 :next-block 1}
        out (opt/optimize f)]
    (is (= [] (:subfunctions out)))))

;; ── optimize: per-block scoping ─────────────────────────────────────────────

(deftest test-optimize-blocks-without-non-escaping-allocs-unchanged
  (let [f {:name "test" :ns "user" :params []
           :next-var 4 :next-block 3 :subfunctions []
           :blocks
           [{:id 0 :phis []
             :insts [{:op :load-local :dst 0 :name "x"}]
             :terminator {:op :jump :target 1}}
            {:id 1 :phis []
             :insts [(alloc-vec 1 [])
                     (call-known 2 :count [1])]
             :terminator (ret 2)}]}
        out (opt/optimize f)
        blocks (:blocks out)]
    (testing "block 0 is unchanged"
      (is (= (-> f :blocks first) (first blocks))))
    (testing "block 1 has region instructions inserted"
      (let [insts (-> blocks second :insts)]
        (is (some (fn [i] (= :region-start (:op i))) insts))
        (is (some (fn [i] (= :region-alloc (:op i))) insts))
        (is (some (fn [i] (= :region-end   (:op i))) insts))))))

;; ── optimize: cross-block dominator scoping (the min-key shape) ────────────

(defn- find-inst [block op]
  (some (fn [i] (when (= op (:op i)) i)) (:insts block)))

(deftest test-optimize-min-key-shape-spans-dominator-subgraph
  ;; Mirror the structure that broke `min-key:3+` before the fix:
  ;;
  ;;   block 0:  branch cond -> block 1, block 2
  ;;   block 1:  alloc-vector [42] -> v1, jump block 3
  ;;   block 2:  alloc-vector [99] -> v2, jump block 3
  ;;   block 3:  v3 = phi(b1->v1, b2->v2)
  ;;             count v3 -> v4
  ;;             return v4
  ;;
  ;; Both allocs are :no-escape (the phi result is consumed by :count).
  ;; lca-of-doms({b1, b2, b3}) = b0; lca-of-postdoms = b3.  So each alloc
  ;; gets a region wrapping b0..b3.
  (let [f {:name "test" :ns "user" :params []
           :next-var 5 :next-block 4 :subfunctions []
           :blocks
           [{:id 0 :phis []
             :insts [{:op :load-local :dst 0 :name "cond"}]
             :terminator {:op :branch :cond 0 :then-block 1 :else-block 2}}
            {:id 1 :phis []
             :insts [(alloc-vec 1 [])]
             :terminator {:op :jump :target 3}}
            {:id 2 :phis []
             :insts [(alloc-vec 2 [])]
             :terminator {:op :jump :target 3}}
            {:id 3
             :phis [{:op :phi :dst 3 :entries [[1 1] [2 2]]}]
             :insts [(call-known 4 :count [3])]
             :terminator (ret 4)}]}
        out (opt/optimize f)
        b0 (nth (:blocks out) 0)
        b1 (nth (:blocks out) 1)
        b2 (nth (:blocks out) 2)
        b3 (nth (:blocks out) 3)]
    (testing "RegionStart goes at the head of the dominator (b0), one per alloc"
      (let [starts (filterv (fn [i] (= :region-start (:op i))) (:insts b0))]
        (is (= 2 (count starts)))))
    (testing "Both allocs in b1 / b2 are rewritten to RegionAlloc"
      (let [b1-alloc (find-inst b1 :region-alloc)
            b2-alloc (find-inst b2 :region-alloc)]
        (is (some? b1-alloc))
        (is (some? b2-alloc))
        (is (= :vector (:kind b1-alloc)))
        (is (= :vector (:kind b2-alloc)))))
    (testing "RegionEnd goes at the tail of the post-dominator (b3), one per region"
      (let [ends (filterv (fn [i] (= :region-end (:op i))) (:insts b3))]
        (is (= 2 (count ends)))))
    (testing "RegionStart precedes the count in b3 — region is alive when counted"
      ;; b0 has region-start; b3 has count then region-end.
      (let [insts (:insts b3)
            count-idx (some (fn [[i v]] (when (= :call-known (:op v)) i))
                            (map-indexed vector insts))
            end-idx (some (fn [[i v]] (when (= :region-end (:op v)) i))
                          (map-indexed vector insts))]
        (is (< count-idx end-idx)
            "count runs before region-end, so the phi result is live")))))

(deftest test-optimize-loop-back-edge-disqualifies
  ;; A loop wrapping the alloc would mean the region's start dominates a
  ;; back-edge — accumulating one bump-allocation per iteration without
  ;; freeing.  The pass refuses to optimize.
  (let [f {:name "test" :ns "user" :params []
           :next-var 4 :next-block 3 :subfunctions []
           :blocks
           [{:id 0 :phis []
             :insts [{:op :const :dst 0 :value {:type :nil}}]
             :terminator {:op :jump :target 1}}
            ;; loop header
            {:id 1
             :phis [{:op :phi :dst 1 :entries [[0 0]]}]
             :insts [(alloc-vec 2 [])
                     (call-known 3 :count [2])]
             :terminator {:op :branch :cond 3 :then-block 1 :else-block 2}}
            ;; exit
            {:id 2 :phis []
             :insts []
             :terminator (ret 1)}]}
        out (opt/optimize f)
        b1 (nth (:blocks out) 1)]
    (testing "no region instructions in the loop body"
      (is (not (some (fn [i] (= :region-start (:op i))) (:insts b1))))
      (is (not (some (fn [i] (= :region-alloc (:op i))) (:insts b1))))
      (is (not (some (fn [i] (= :region-end   (:op i))) (:insts b1)))))
    (testing "alloc remains a regular alloc-vector"
      (is (some (fn [i] (= :alloc-vector (:op i))) (:insts b1))))))

(deftest test-optimize-throw-disqualifies
  ;; If a block in the proposed region has a `:throw` terminator, region
  ;; cleanup wouldn't fire on the unwind path.  Refuse to optimize.
  (let [f {:name "test" :ns "user" :params []
           :next-var 4 :next-block 3 :subfunctions []
           :blocks
           [{:id 0 :phis []
             :insts [{:op :load-local :dst 0 :name "cond"}]
             :terminator {:op :branch :cond 0 :then-block 1 :else-block 2}}
            ;; happy path — has the alloc
            {:id 1 :phis []
             :insts [(alloc-vec 1 [])]
             :terminator {:op :jump :target 2}}
            ;; converges; uses alloc
            {:id 2
             :phis [{:op :phi :dst 2 :entries [[1 1] [0 0]]}]
             :insts [(call-known 3 :count [2])
                     {:op :throw :value 3}]
             :terminator {:op :unreachable}}]}
        out (opt/optimize f)
        b1 (nth (:blocks out) 1)]
    (testing "alloc stays as alloc-vector — region would span a throw"
      (is (some (fn [i] (= :alloc-vector (:op i))) (:insts b1)))
      (is (not (some (fn [i] (= :region-alloc (:op i))) (:insts b1)))))))

;; ── CFG analysis primitives ────────────────────────────────────────────────

(deftest test-block-successors
  (is (= [3] (opt/block-successors {:terminator {:op :jump :target 3}})))
  (is (= [1 2] (opt/block-successors {:terminator {:op :branch :cond 0 :then-block 1 :else-block 2}})))
  (is (= [0] (opt/block-successors {:terminator {:op :recur-jump :target 0 :args []}})))
  (is (= [] (opt/block-successors {:terminator {:op :return :var 0}})))
  (is (= [] (opt/block-successors {:terminator {:op :throw :value 0}})))
  (is (= [] (opt/block-successors {:terminator {:op :unreachable}}))))

(deftest test-predecessor-map-for-diamond
  (let [f {:blocks [{:id 0 :terminator {:op :branch :cond 0 :then-block 1 :else-block 2}}
                    {:id 1 :terminator {:op :jump :target 3}}
                    {:id 2 :terminator {:op :jump :target 3}}
                    {:id 3 :terminator (ret 0)}]}
        preds (opt/predecessor-map f)]
    (is (= #{0} (get preds 1)))
    (is (= #{0} (get preds 2)))
    (is (= #{1 2} (get preds 3)))))

(deftest test-dominators-for-diamond
  ;; b0
  ;;  ├─ b1 ─┐
  ;;  │      ↓
  ;;  └─ b2 ─→ b3
  ;; Every reachable block is dominated by b0.  b1 and b2 are siblings.
  ;; b3 has two predecessors so its only proper dominator is b0.
  (let [f {:name "x" :ns "u" :params []
           :next-var 0 :next-block 4 :subfunctions []
           :blocks [{:id 0 :phis [] :insts []
                     :terminator {:op :branch :cond 0 :then-block 1 :else-block 2}}
                    {:id 1 :phis [] :insts [] :terminator {:op :jump :target 3}}
                    {:id 2 :phis [] :insts [] :terminator {:op :jump :target 3}}
                    {:id 3 :phis [] :insts [] :terminator (ret 0)}]}
        doms (opt/dominators f)]
    (is (= #{0} (get doms 0)))
    (is (= #{0 1} (get doms 1)))
    (is (= #{0 2} (get doms 2)))
    (is (= #{0 3} (get doms 3)))))

(deftest test-post-dominators-for-diamond
  ;; In the same diamond, b3 post-dominates b0, b1, b2 (all paths reach
  ;; b3 before exiting).
  (let [f {:name "x" :ns "u" :params []
           :next-var 0 :next-block 4 :subfunctions []
           :blocks [{:id 0 :phis [] :insts []
                     :terminator {:op :branch :cond 0 :then-block 1 :else-block 2}}
                    {:id 1 :phis [] :insts [] :terminator {:op :jump :target 3}}
                    {:id 2 :phis [] :insts [] :terminator {:op :jump :target 3}}
                    {:id 3 :phis [] :insts [] :terminator (ret 0)}]}
        pdoms (opt/post-dominators f)]
    (is (contains? (get pdoms 0) 3))
    (is (contains? (get pdoms 1) 3))
    (is (contains? (get pdoms 2) 3))
    (is (= #{3} (get pdoms 3)))))

(deftest test-lca-of-many-collapses-to-common-ancestor
  ;; In the diamond, lca of {1, 2, 3} in the dominator tree is 0.
  (let [f {:name "x" :ns "u" :params []
           :next-var 0 :next-block 4 :subfunctions []
           :blocks [{:id 0 :phis [] :insts []
                     :terminator {:op :branch :cond 0 :then-block 1 :else-block 2}}
                    {:id 1 :phis [] :insts [] :terminator {:op :jump :target 3}}
                    {:id 2 :phis [] :insts [] :terminator {:op :jump :target 3}}
                    {:id 3 :phis [] :insts [] :terminator (ret 0)}]}
        doms (opt/dominators f)]
    (is (= 0 (opt/lca-of-many doms #{1 2 3})))
    (is (= 1 (opt/lca-of-many doms #{1})))
    (is (= 0 (opt/lca-of-many doms #{1 3})))))
